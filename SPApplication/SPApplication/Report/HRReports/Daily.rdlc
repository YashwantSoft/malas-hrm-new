                                <TextRun>
                                  <Value>="Total: Present=" &amp; Sum(iif(Fields!Status.Value ="P",1,0)) &amp;", Absent=" &amp; Sum(iif(Fields!Status.Value ="A",1,0))  &amp;", Weekly Off=" &amp; Sum(iif(Fields!Status.Value ="WO",1,0))  &amp;", Holiday=" &amp; Sum(iif(Fields!Status.Value ="H",1,0)) &amp;", Late=" &amp; Sum(iif(Fields!LateBy.Value &gt; 0,1,0)) &amp;", Early=" &amp; Sum(iif(Fields!EarlyBy.Value &gt; 0,1,0)) &amp;", Missed In Punch=" &amp; Sum(iif(Fields!MissedInPunch.Value = "-1",1,0)) &amp;", Missed Out Punch=" &amp; Sum(iif(Fields!MissedOutPunch.Value = "-1",1,0))</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
